{
  "name": "background-coding-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "AI coding agent that creates pull requests by autonomously coding in isolated Docker containers",
  "main": "dist/index.js",
  "bin": {
    "background-agent": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start:cli": "npx tsx src/cli/index.ts",
    "test": "vitest run",
    "test:agent": "npx tsx src/orchestrator/agent.test.ts",
    "test:container": "npx tsx src/orchestrator/container.test.ts",
    "test:session": "npx tsx src/orchestrator/session.test.ts",
    "test:unit": "vitest run src/orchestrator/retry.test.ts src/orchestrator/summarizer.test.ts src/orchestrator/verifier.test.ts",
    "test:all": "npm run test:container && npm run test:agent && npm run test:session && npm run test:unit",
    "lint": "eslint ."
  },
  "keywords": [
    "ai",
    "claude",
    "docker",
    "automation",
    "coding-agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@anthropic-ai/sdk": "^0.71.2",
    "commander": "^14.0.3",
    "dockerode": "^4.0.2",
    "octokit": "^5.0.5",
    "picocolors": "^1.1.1",
    "pino": "^10.3.0",
    "simple-git": "^3.32.3",
    "write-file-atomic": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dockerode": "^3.3.36",
    "@types/node": "^20.17.10",
    "@types/write-file-atomic": "^4.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^10.0.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
